PORT=5600
NODE_ENV=development
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net
CORS_ORIGIN=*

# Brevo API key for contact form email delivery
BREVO_API_KEY=your-brevo-api-key

# Where inquiry emails should be delivered
CONTACT_RECEIVER_EMAIL=you@yourdomain.com

# Sender address must be verified in your Brevo account
CONTACT_FROM_EMAIL=verified-sender@yourdomain.com

# Optional sender name
CONTACT_FROM_NAME=OpenGen Contact Form
